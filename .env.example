# Supabase (Settings -> API in your Supabase project)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin login
# Generate ADMIN_PASSWORD_HASH_B64 with: node -e "console.log(Buffer.from(require('bcryptjs').hashSync('yourpassword', 10)).toString('base64'))"
ADMIN_PASSWORD_HASH_B64=
# Any long random string, e.g. `openssl rand -hex 32`
ADMIN_SESSION_SECRET=

# Amazon Product Advertising API (requires an Associates account with
# qualifying recent sales — apply at https://webservices.amazon.com/paapi5/documentation/)
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_ASSOCIATES_TAG=

# Discord — comma separated list of webhook URLs
DISCORD_WEBHOOK_URLS=

# Vercel Cron auth — any long random string, must match vercel.json's cron call
CRON_SECRET=
